# Twind declares typescript@^4.8.4 as a peerOptional dep; we run TS 5.9.
# It's optional + only used for type checks inside the lib, so the
# version mismatch is harmless. Vercel's default `npm install` is strict
# on peer deps and refuses to resolve the tree without this flag.
# Same flag is implicit when running `npm install --legacy-peer-deps`
# locally; setting it in .npmrc makes the behavior consistent across
# environments.
legacy-peer-deps=true
