{
  "name": "videoai-render-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Remotion render service for videoai. Receives manifest, outputs MP4, uploads to Supabase Storage.",
  "scripts": {
    "bundle": "node --loader ts-node/esm scripts/bundle.ts",
    "build": "tsc && npm run bundle",
    "start": "node dist/server.js",
    "dev": "node --loader ts-node/esm src/server.ts"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "express": "^4.21.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "remotion": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
